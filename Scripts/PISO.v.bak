module PISO # (
    parameter ANCHO = 16
)(
    input wire clk,
    input wire reset,
    input wire load,
    input wire shift,
    input wire [ANCHO-1:0] parallel_in,

    output wire serial_out
);

    reg [ANCHO-16:0] shift_register;

    always @(posedge clk) begin
        if (reset) begin
            shift_register <= 16'b0;
        end

        else if (load) begin
            shift_register <= parallel_in;
        end

        else if (shift_in) begin
            shift_reg <= shift_reg >> 1;
        end
    end

    assign serial_out = shift_register[0];

endmodule