`timescale 1ns / 1ps

module Sensor_receiver;

    // 1. Parámetros del Testbench
    parameter ANCHO = 16;

    // 2. Declaración de Señales de Estímulo (Entradas al DUT = reg)
    reg clk;
    reg reset;
    reg clk_datos;
    reg ini_fin;
    reg bit_entrada;

    // 3. Declaración de Señales de Respuesta (Salidas del DUT = wire)
    wire signed [ANCHO-1:0] Y;
    wire start_tick;

    // Variables auxiliares para el generador de estímulos
    integer i;
    reg [ANCHO-1:0] dato_prueba;

    // 4. Instanciación del Dispositivo Bajo Prueba (DUT)
    Sensor_receiver #(
        .ANCHO(ANCHO)
    ) dut (
        .clk(clk),
        .reset(reset),
        .clk_datos(clk_datos),
        .ini_fin(ini_fin),
        .bit_entrada(bit_entrada),
        .Y(Y),
        .start_tick(start_tick)
    );

    // 5. Generación del Reloj Principal del Sistema
    // Simulamos un reloj rápido, por ejemplo a 50 MHz (periodo de 20ns)
    always begin
        #10 clk = ~clk;
    end

    // 6. Secuencia Lógica de Simulación
    initial begin
        // Fase A: Inicialización y Reset
        clk = 0;
        reset = 1;      // Tu código asume un reset activo a nivel ALTO
        clk_datos = 0;
        ini_fin = 0;
        bit_entrada = 0;
        
        // Dato que el sensor ficticio va a enviar (Ej: 16'hA53C)
        dato_prueba = 16'hA53C; 

        #50;            // Esperamos unos ciclos para estabilizar
        reset = 0;      // Liberamos el circuito
        #50;

        // Fase B: Emulación de la Transmisión del Sensor (SPI / SIPO)
        // Levantamos la señal de validación
        ini_fin = 1; 
        
        // Damos tiempo para que los sincronizadores de doble FF capturen 'ini_fin'
        #60; 

        // Bucle para enviar los 16 bits (Desde el MSB al LSB)
        for (i = ANCHO-1; i >= 0; i = i - 1) begin
            
            // Colocamos el bit en la línea de datos
            bit_entrada = dato_prueba[i]; 
            #40; // Tiempo de Setup (espera antes del flanco de reloj)

            // Flanco de subida del reloj del sensor
            clk_datos = 1; 
            #40; // Tiempo de Hold (mantenimiento del reloj en alto)

            // Flanco de bajada del reloj del sensor
            clk_datos = 0; 
            #40; // Tiempo de inactividad antes del siguiente bit
            
        end

        // Fase C: Finalización de la Trama y Carga de Salida
        #40;
        ini_fin = 0; // Bajamos la señal: esto disparará el detector de flanco de bajada

        // Dejamos correr la simulación suficiente tiempo para observar el 'start_tick'
        #200;

        // Imprimimos el resultado en la consola de ModelSim
        $display("========================================");
        $display("Dato enviado por el sensor : %h", dato_prueba);
        $display("Dato recibido por el modulo: %h", Y);
        $display("========================================");
        
        $stop; // Detenemos el simulador
    end

endmodule